<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ZapretKotlin" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/background_night</item>
        <item name="android:fontFamily">@font/montserrat_regular</item>
        <item name="android:textColor">@color/text_light</item>
    </style>

    <style name="CardView_style" parent="Theme.Material3.DayNight">
        <item name="android:backgroundTint">@color/card_color_night</item>
        <item name="cardCornerRadius">30dp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Button_style">
        <item name="android:backgroundTint">@color/button_color_night</item>
        <item name="android:textColor">@color/btn_text_night</item>
    </style>

    <style name="Alert_style">
        <item name="android:background">@color/background_night</item>
    </style>
</resources>